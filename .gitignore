# R session and history
.Rhistory
.Rapp.history
.Rproj.user/
.RData
.Ruserdata

# RStudio
*.Rproj

# macOS
.DS_Store

# Editor backups
*~
*.swp
*.swo

# Logs and ephemeral outputs
outputs/orchestrator_logs/*.log

# Large derived data (regenerated by the pipeline)
data_derived/**/*.rds
data_derived/**/*.csv
data_derived/**/*.txt

# Raw data (kept out of public repo; deposited separately per data-availability statement)
data_raw/**/*.csv
data_raw/**/*.tsv
data_raw/**/*.rds
data_raw/**/*.vcf
data_raw/**/*.vcf.gz
data_raw/**/*.bam
data_raw/**/*.fastq
data_raw/**/*.fastq.gz

# Keep inherited Paper 1 threshold RDS files visible to reviewers (small, integral to pre-spec)
!data_raw/paper1_thresholds/*.rds

# Manuscript working files
*.docx
*.aux
*.log
*.out
*.synctex.gz
*.toc
*.bbl
*.blg
*.fdb_latexmk
*.fls

# OS / archive cruft
Thumbs.db
.envrc
.env